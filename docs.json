  "metadata": {
    "og:title": "Adhere API — KYC, Fraud Detection & Credit Reports for Africa",
    "og:description": "One API for identity verification, real-time fraud detection, transaction monitoring, and credit reports across Nigeria, Ghana, Kenya, Rwanda, and Uganda. Built for developers by Smartcomply.",
    "og:site_name": "Adhere by Smartcomply",
    "twitter:title": "Adhere API — KYC, Fraud Detection & Credit Reports for Africa",
    "twitter:description": "Verify identities, screen transactions, and access credit data across Africa with the Adhere API. One integration. Five countries.",
    "description": "Developer documentation for the Adhere API by Smartcomply. Covers KYC identity verification, fraud detection, transaction monitoring, credit reports, and loan fraud checks across Nigeria, Ghana, Kenya, Rwanda, and Uganda."
  },
